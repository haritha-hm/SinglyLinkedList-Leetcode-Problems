class Solution {
    public ListNode deleteMiddle(ListNode head) {
        if(head==null)return null;
        ListNode dummy=new ListNode(0);
        dummy.next=head;
        ListNode s=dummy;
        ListNode f=head;
        while(f!=null&&f.next!=null){
            s=s.next;
            f=f.next.next;
        }
        s.next=s.next.next;
        return dummy.next;
    }
}
